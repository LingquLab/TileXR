        <mxCell id="bottom_note" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontFamily=Comic Sans MS;fontColor=#333333;strokeColor=none;fillColor=none;whiteSpace=wrap;" value="&lt;font&gt;Tile readiness turns coarse phase gaps into overlapping in-flight work across AICores.&lt;br&gt;&lt;b&gt;&lt;span style=&quot;color: rgb(26, 28, 31); text-align: start;&quot;&gt;*AIV transfer overhead can be further reduced through in-operator direct invocation of SDM&lt;/span&gt;&lt;span style=&quot;color: rgb(26, 28, 31); text-align: start;&quot;&gt;A/UDMA, freeing AIV&lt;/span&gt;&lt;span style=&quot;color: rgb(26, 28, 31); text-align: start;&quot;&gt; for compute.&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;" vertex="1">
